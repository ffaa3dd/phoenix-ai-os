# Database
DATABASE_URL=postgresql://user:password@localhost:5432/phoenix_ai_os
DATABASE_USER=phoenix_user
DATABASE_PASSWORD=secure_password_here
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Trading API
TRADING_API_PORT=3000
TRADING_API_HOST=0.0.0.0
API_SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# AI Core
AI_CORE_PORT=8000
AI_CORE_HOST=0.0.0.0
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Rise SDK
RISE_SDK_API_KEY=your_rise_sdk_key
RISE_SDK_SECRET=your_rise_sdk_secret
PHOENIX_EXCHANGE_URL=https://api.phoenix.exchange

# Trading Configuration
TRADING_MODE=paper
MAX_POSITION_SIZE=10000
MAX_DAILY_LOSS_PERCENT=5
RISK_PER_TRADE=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Development
DEBUG=false
